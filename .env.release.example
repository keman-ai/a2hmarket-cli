# Copy this file to .env.release.local and replace the placeholders.
# These variable names match the GitHub Actions secrets expected by release.yml.

export APPLE_CERT_P12_PATH="$HOME/Desktop/a2hmarket-cli-dev-id.p12"
export APPLE_CERTIFICATE_PASSWORD="replace-with-your-p12-password"
export APPLE_KEYCHAIN_PASSWORD="replace-with-a-temporary-ci-keychain-password"

export APPLE_DEV_ID_APP="Developer ID Application: Your Company Name (TEAMID)"
export APPLE_NOTARY_APPLE_ID="replace-with-your-apple-id@example.com"
export APPLE_NOTARY_TEAM_ID="TEAMID"
export APPLE_NOTARY_APP_PASSWORD="replace-with-your-app-specific-password"

# Optional: override the target repo when pushing secrets with the helper script.
# export GH_REPO="keman-ai/a2hmarket-cli"
